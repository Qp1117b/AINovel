{
  "version": "2.0",
  "description": "互动小说自动化创作系统完整配置（含剧情策划师、规则设计师、交互代理、交互分析师）- 元Agent版（已移除最终保存器）",
  "maxStateBooks": 3,
  "stateTypeLimit": 30,
  "maxConsecutiveReflows": 3,
  "maxReflowDepth": 100,
  "mode": "interactive",
  "apiConfigs": {
    "sd-webui": {
      "type": "image",
      "source": "sdwebui",
      "apiUrl": "http://127.0.0.1:7860",
      "key": "",
      "mode": "",
      "model": "v1-5-pruned-emaonly.safetensors",
      "steps": 20,
      "cfg_scale": 7,
      "width": 512,
      "height": 512,
      "sampler_name": "DPM++ 2M",
      "negative_prompt": "nsfw, low quality, blurry",
      "timeout": 10000000
    }
  },
  "workflowStages": [
    {
      "stage": 1,
      "id": "planning",
      "name": "规则设计",
      "color": "#9b59b6",
      "description": "负责整体剧情策划与规则设计",
      "agents": [
        "P1",
        "R1"
      ],
      "mode": "serial"
    },
    {
      "stage": 2,
      "id": "writing",
      "name": "场景创作",
      "color": "#f39c12",
      "description": "生成场景文本",
      "agents": [
        "W1"
      ],
      "mode": "serial"
    },
    {
      "stage": 3,
      "id": "image",
      "name": "图像生成",
      "color": "#8e44ad",
      "description": "生成元素图片",
      "agents": [
        "G1"
      ],
      "mode": "serial"
    },
    {
      "stage": 4,
      "id": "fusion",
      "name": "融合",
      "color": "#e67e22",
      "description": "将元素图融合成完整场景",
      "agents": [
        "G2"
      ],
      "mode": "serial"
    },
    {
      "stage": 5,
      "id": "typeset",
      "name": "排版",
      "color": "#1abc9c",
      "description": "合成初始HTML场景",
      "agents": [
        "T1"
      ],
      "mode": "serial"
    },
    {
      "stage": 6,
      "id": "interaction",
      "name": "交互",
      "color": "#e74c3c",
      "description": "处理用户交互",
      "agents": [
        "IA"
      ],
      "mode": "serial"
    },
    {
      "stage": 7,
      "id": "analysis",
      "name": "分析",
      "color": "#ff8c00",
      "description": "生成带状态草稿的分析文本",
      "agents": [
        "IA2"
      ],
      "mode": "serial"
    },
    {
      "stage": 8,
      "id": "summary",
      "name": "概览",
      "color": "#3498db",
      "description": "生成累积故事概览",
      "agents": [
        "S1"
      ],
      "mode": "serial"
    },
    {
      "stage": 9,
      "id": "state_opt",
      "name": "优化",
      "color": "#27ae60",
      "description": "状态优化",
      "agents": [
        "M1"
      ],
      "mode": "serial"
    },
    {
      "stage": 10,
      "id": "state_maint",
      "name": "维护",
      "color": "#27ae60",
      "description": "状态维护",
      "agents": [
        "M2"
      ],
      "mode": "serial"
    }
  ],
  "agents": {
    "P1": {
      "name": "通用生成器",
      "displayName": "剧情策划师",
      "hover": "根据上一章概览策划本章剧情走向",
      "role": "",
      "stage": "planning",
      "order": 3,
      "required": true,
      "parallel": false,
      "apiConfigId": "",
      "inputs": [
        "S1.last"
      ],
      "inputTemplate": "【职能】你现在是剧情策划师，请根据上一章的累积故事概览，策划本章的剧情走向和关键事件。\n\n【职能规则】1. 输出应包含本章的核心冲突、人物发展目标、悬念设置；2. 保持与故事概览的逻辑连贯。\n\n【唯一输出格式】\n===剧情策划===\n核心冲突：\n\n人物发展目标：\n\n悬念设置：\n\n\n【输入】\n上一章概览：\n【】\n\n请严格按照格式输出。",
      "inputMode": [
        "txt"
      ],
      "autoConfig": [
        0
      ],
      "inputPrompts": [
        ""
      ],
      "outputs": [
        "剧情策划"
      ],
      "description": "策划本章剧情",
      "reflowConditions": [],
      "executeInterval": 0,
      "review": false
    },
    "R1": {
      "name": "通用生成器",
      "displayName": "互动小说规则设计师",
      "hover": "根据上一章概览设计本章交互规则（JSON格式）",
      "role": "",
      "stage": "planning",
      "order": 5,
      "required": true,
      "parallel": false,
      "apiConfigId": "",
      "inputs": [
        "S1.last"
      ],
      "inputTemplate": "【职能】你现在是互动小说规则设计师，请根据上一章的累积故事概览，设计本章的交互效果规则。\n\n【职能规则】1. 输出必须为严格的JSON格式；2. 必须包含type字段，可选值包括\"choice\"、\"dice\"、\"dialogue\"等；3. 必须包含effects数组，每个effect包含range、description、stateChanges；4. 对于dice类型，必须包含range字段；5. 状态变化使用点号表示嵌套属性。\n\n【唯一输出格式】JSON对象，例如：\n{\n  \"type\": \"dice\",\n  \"range\": \"1-6\",\n  \"effects\": [\n    {\"range\": \"1-2\", \"description\": \"受伤\", \"stateChanges\": {\"体力\": -10}},\n    ...\n  ]\n}\n\n【输出示例】见上。\n\n【输入】\n故事概览：\n【】\n\n请严格按照格式输出JSON，不要包含任何额外文字。",
      "inputMode": [
        "txt"
      ],
      "autoConfig": [
        0
      ],
      "inputPrompts": [
        ""
      ],
      "outputs": [
        "交互规则"
      ],
      "description": "设计本章交互规则",
      "reflowConditions": [],
      "executeInterval": 0,
      "review": false
    },
    "W1": {
      "name": "通用生成器",
      "displayName": "互动小说场景师",
      "hover": "根据规则、概览和上一轮选择生成【画面】【正文】【交互描述】",
      "role": "finalChapter",
      "stage": "writing",
      "order": 10,
      "required": true,
      "parallel": false,
      "apiConfigId": "",
      "inputs": [
        "R1",
        "S1.last",
        "IA.last"
      ],
      "inputTemplate": "【职能】你现在是互动小说场景师，负责根据交互规则、上一章累积故事概览和玩家上一轮选择，生成当前场景的【画面】视觉描述、【正文】故事叙述和【交互描述】。\n\n【职能规则】1. 输出必须严格分为三部分，用空行分隔；2. 【画面】描述必须包含位置、光影、相对大小等视觉细节，不得包含文字对话；3. 【正文】必须遵循第四面墙原则，不得提及玩家或交互，可分段；4. 【交互描述】必须包含触发时机、类型、选项等，格式严格参照模板；5. 所有部分必须完整。\n\n【唯一输出格式】\n【画面】\n（画面描述）\n\n【正文】\n（故事文本，可分段）\n\n【交互描述】\n触发时机: [时机]\n类型: [类型]\n选项:\n- [选项1]\n- [选项2]\n范围: [仅dice]\n提示: [仅dialogue或dice]\n时限: [仅timer]\n（请严格按照此格式，不得添加额外字段）\n\n【输出示例】\n【画面】\n背景：学校天台，黄昏，夕阳从右侧照射...\n【正文】\n你站在天台...\n【交互描述】\n触发时机: 对话后\n类型: choice\n选项:\n- 约她出去玩\n- 保持沉默\n\n【输入】\n交互规则：\n【】\n上一章累积故事概览：\n【】\n玩家上一轮选择：\n【】\n\n请严格按照上述格式生成场景。",
      "inputMode": [
        "txt",
        "txt",
        "txt"
      ],
      "autoConfig": [
        0,
        0,
        0
      ],
      "inputPrompts": [
        "",
        "",
        ""
      ],
      "outputs": [
        "画面",
        "正文",
        "交互描述"
      ],
      "description": "生成场景核心内容",
      "reflowConditions": [],
      "executeInterval": 0,
      "review": false
